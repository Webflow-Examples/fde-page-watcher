# Copy to .env.local and fill in as needed. All are optional for local dev.

# PageSpeed Insights API key — raises quota/reliability. PSI works keyless at
# low volume, so this is optional. https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Number of PSI runs per strategy (1–5). Defaults to 5 (the spec). Set to 1 for
# quick manual checks so a "Run now" completes in seconds.
PSI_RUNS=5

# Slack incoming webhook for drop alerts and follow-up reports. If unset, the
# notifier logs and no-ops.
SLACK_WEBHOOK_URL=

# Shared secret required to POST /api/cron/nightly. If unset, the endpoint is
# open (fine for local dev only).
CRON_SECRET=

# Claude API key for the Watcher's dashboard narrative and per-recommendation
# explanations, generated once per nightly run. If unset, both fall back to
# the templated (non-AI) text/no summary. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Set to skip the real Anthropic call and return deterministic placeholder
# text — for local dev/testing without spending API budget.
ANTHROPIC_MOCK=
