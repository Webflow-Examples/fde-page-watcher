{
  "name": "fde-page-watcher",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv --include-runtime false ./cloudflare-env.d.ts",
    "collector:typegen": "wrangler types --config collector-worker/wrangler.jsonc collector-worker/worker-configuration.d.ts",
    "collector:check": "tsc -p collector-worker/tsconfig.json",
    "collector:dry-run": "wrangler deploy --dry-run --config collector-worker/wrangler.jsonc",
    "collector:deploy": "wrangler deploy --config collector-worker/wrangler.jsonc",
    "test": "vitest run"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4"
  }
}
